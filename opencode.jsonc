{
	"$schema": "https://opencode.ai/config.json",
	"permission": {
		"bash": {
			"git commit*-n*": "deny",
			"git commit*--no-verify*": "deny",
			"*.git*": "deny"
		},
		"edit": {
			"lefthook.yml": "ask",
			"opencode.jsonc": "ask",
			".git/*": "deny",
			"node_modules/*": "deny",
			"logs/*": "deny",
			"/tmp/*": "allow"
		}
	},
	"agent": {
		"ralph": {
			"description": "Hands-off agent for usage with Ralph Loops",
			"mode": "primary",
			"model": "github-copilot/gpt-5.3-codex",
			"reasoningEffort": "xhigh",
			// "textVerbosity": "low",
			"tools": {
				"web-search_*": false
			},
			"permission": {
				"edit": {
					"lefthook.yml": "deny",
					"opencode.jsonc": "deny",
					"logs/*": "deny"
				}
			}
		}
	},
	"mcp": {
		"web-scraping": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"pyd4vinci/scrapling",
				"mcp"
			],
			"enabled": false
		},
		"tech-docs": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
			"enabled": true
		},
		"web-search": {
			"type": "local",
			"command": [
				"npx", "-y", "open-websearch@latest"
			],
			"environment": {
				"MODE": "stdio",
				"DEFAULT_SEARCH_ENGINE": "duckduckgo"
			},
			"enabled": true
		},
		"code-examples": {
			"type": "remote",
			"url": "https://mcp.grep.app",
			"enabled": true
		},
		"public-data": {
			"type": "remote",
			"url": "https://api.datacommons.org/mcp",
			"headers": {
				"X-API-Key": "{env:DATACOMMONS_API_KEY}"
			},
			"enabled": false
		},
		"repository-context": {
			"type": "remote",
			"url": "https://gitmcp.io/docs",
			"enabled": true
		},
		"async-bash": {
				"type": "local",
				"command": ["uvx", "async-bash-mcp"],
				"enabled": false
		}
	},
	"plugin": [
		"envsitter-guard@latest",
		"@slkiser/opencode-quota"
		// "opencode-mystatus",
		// "@tarquinen/opencode-dcp@latest",
		// "opencode-pty",
		// "oh-my-opencode@latest"
	],
	// "experimental": {
	// 	"quotaToast": {
	// 		"enabledProviders": [
	// 			"copilot",
	// 			// "openai",
	// 			// "google-antigravity"
	// 		]
	// 	}
	// }
}
