root = true

[*]
charset                   = utf-8
indent_style              = space

[{*.{php,sh,js}}]
end_of_line               = lf
indent_size               = 4
trim_trailing_whitespace  = true
insert_final_newline      = true

[{*.{yml,yaml,json,jsonc},.editorconfig}]
end_of_line               = lf
indent_size               = 2
trim_trailing_whitespace  = true
insert_final_newline      = true

[composer.{json,lock}]
indent_size               = 4

[{*.neon}]
end_of_line               = lf
indent_style              = tab
trim_trailing_whitespace  = true
insert_final_newline      = true

[*.md]
end_of_line               = lf
indent_size               = 2
trim_trailing_whitespace  = false
insert_final_newline      = true

[vendor/**]
ignore                    = true
