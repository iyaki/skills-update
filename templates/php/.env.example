# PHP Environment Configuration Template
# Copy this file to .env and update with your local settings

# Application
APP_NAME="PHP AI Harness"
APP_VERSION="0.1.0"
APP_ENV="development"
APP_DEBUG=true

# Database (example)
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=app_db
# DB_USERNAME=app_user
# DB_PASSWORD=secret

# Logging
LOG_LEVEL="debug"

# Testing
TEST_ENV="testing"
COVERAGE_MIN=99
